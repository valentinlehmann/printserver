# ---- Printer addressing -------------------------------------------------
# IP of the Canon GX7100 (or any IPP/eSCL printer) on the LAN.
# Leave empty for offline development (UI falls back to static capabilities).
PRINTER_IP=192.168.1.50
PRINTER_IPP_PORT=631
PRINTER_IPP_PATH=/ipp/print
PRINTER_ESCL_SCHEME=http
PRINTER_ESCL_PORT=80
PRINTER_ESCL_PATH=/eSCL

# Serve fixtures instead of hitting hardware (1/true to enable).
PRINTER_MOCK=0

# ---- Auth ---------------------------------------------------------------
# Generate a strong secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# Public URL the app is reached at (behind Caddy). Used for cookies + WebAuthn.
BETTER_AUTH_URL=http://localhost:3000
# WebAuthn Relying Party ID = the registrable host (NO scheme, NO port).
# Must match the host in BETTER_AUTH_URL (use "localhost" for local dev).
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Familie Drucker

# ---- Persistence & limits ----------------------------------------------
# In Docker this points at the mounted volume, e.g. /data/sqlite.db.
DATABASE_PATH=./data/sqlite.db
MAX_UPLOAD_MB=100
SCAN_JOB_TTL_SECONDS=900

# ---- Seeding (optional) -------------------------------------------------
SEED_ADMIN_EMAIL=info@valentinlehmann.de
SEED_ADMIN_NAME=Admin
